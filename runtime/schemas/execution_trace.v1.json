{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Execution Trace",
  "description": "Structured execution trace capturing stage transitions, events, and timestamps",
  "type": "object",
  "required": [
    "schema_version",
    "trace_kind",
    "session_id",
    "job_id",
    "trace_events",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "trace_kind": {
      "type": "string",
      "const": "execution_trace"
    },
    "session_id": {
      "type": "string",
      "description": "Session identifier"
    },
    "job_id": {
      "type": "string",
      "description": "Job identifier"
    },
    "objective": {
      "type": ["string", "null"],
      "description": "Execution objective"
    },
    "trace_events": {
      "type": "array",
      "description": "Ordered list of trace events",
      "items": {
        "type": "object",
        "required": [
          "event_type",
          "stage",
          "timestamp",
          "duration_seconds"
        ],
        "additionalProperties": false,
        "properties": {
          "event_type": {
            "type": "string",
            "enum": [
              "stage_start",
              "stage_complete",
              "stage_error",
              "command_started",
              "command_completed",
              "artifact_emitted",
              "profile_selected"
            ]
          },
          "stage": {
            "type": "string",
            "description": "Execution stage: session_job, profile_selection, workspace_init, command_execution, artifact_emission, workspace_finalize"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "duration_seconds": {
            "type": "number",
            "minimum": 0
          },
          "details": {
            "type": "object",
            "description": "Event-specific details"
          },
          "error": {
            "type": ["string", "null"],
            "description": "Error message if stage_error event"
          }
        }
      }
    },
    "total_duration_seconds": {
      "type": "number",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
