{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workspace State Schema",
  "description": "Runtime workspace state and path structure",
  "type": "object",
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Session identifier"
    },
    "job_id": {
      "type": "string",
      "description": "Job identifier"
    },
    "workspace_root": {
      "type": "string",
      "description": "Root directory path for this workspace"
    },
    "scratch_dir": {
      "type": "string",
      "description": "Scratch directory for temporary files"
    },
    "artifact_dir": {
      "type": "string",
      "description": "Artifact directory for persistent outputs"
    },
    "lock_file": {
      "type": "string",
      "description": "Path to workspace lock file"
    },
    "status": {
      "type": "string",
      "description": "Current workspace status",
      "enum": ["initialized", "active", "finalized"]
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of workspace creation"
    },
    "finalized_at": {
      "type": ["string", "null"],
      "description": "ISO 8601 timestamp of workspace finalization"
    }
  },
  "required": ["session_id", "job_id", "workspace_root", "scratch_dir", "artifact_dir", "lock_file", "status", "created_at"],
  "additionalProperties": false
}
