{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Inference Response Schema",
  "description": "Response from inference gateway with routing decision and telemetry",
  "type": "object",
  "properties": {
    "selected_profile": {
      "type": "string",
      "description": "Selected profile (fast/balanced/hard)",
      "enum": ["fast", "balanced", "hard"]
    },
    "backend": {
      "type": "string",
      "description": "Backend system (ollama or claude_api)",
      "enum": ["ollama", "claude_api"]
    },
    "model": {
      "type": "string",
      "description": "Model identifier"
    },
    "timeout_seconds": {
      "type": "integer",
      "description": "Timeout in seconds for this request"
    },
    "max_retries": {
      "type": "integer",
      "description": "Maximum retry attempts"
    },
    "context_window_tokens": {
      "type": "integer",
      "description": "Available context window in tokens"
    },
    "rationale": {
      "type": "string",
      "description": "Explanation for profile selection"
    },
    "telemetry": {
      "type": "object",
      "description": "Telemetry metadata for this routing decision",
      "properties": {
        "selection_timestamp": {
          "type": "string",
          "description": "ISO 8601 timestamp of selection"
        },
        "selection_factors": {
          "type": "array",
          "description": "Factors that influenced this decision",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    }
  },
  "required": ["selected_profile", "backend", "model", "timeout_seconds", "max_retries"],
  "additionalProperties": false
}
