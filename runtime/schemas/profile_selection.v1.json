{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Profile Selection Schema",
  "description": "Decision log for profile selection reasoning",
  "type": "object",
  "properties": {
    "goal": {
      "type": "string",
      "description": "The goal being evaluated"
    },
    "selected_profile": {
      "type": "string",
      "description": "Selected profile",
      "enum": ["fast", "balanced", "hard"]
    },
    "selection_factors": {
      "type": "array",
      "description": "Factors considered in selection",
      "items": {
        "type": "object",
        "properties": {
          "factor": {"type": "string"},
          "value": {"type": ["string", "number", "boolean"]},
          "weight": {"type": "number"}
        }
      }
    },
    "scores": {
      "type": "object",
      "description": "Score breakdown for each candidate profile",
      "properties": {
        "fast": {"type": "number"},
        "balanced": {"type": "number"},
        "hard": {"type": "number"}
      }
    },
    "explicit_escalation": {
      "type": "boolean",
      "description": "Was explicit escalation requested"
    }
  },
  "required": ["goal", "selected_profile"],
  "additionalProperties": false
}
