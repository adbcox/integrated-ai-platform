{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Runtime Run Artifact Schema",
  "description": "Complete record of a bounded runtime execution with routing, workspace, and results",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version identifier",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "artifact_kind": {
      "type": "string",
      "description": "Artifact type",
      "enum": ["runtime_run_artifact"]
    },
    "session_id": {
      "type": "string",
      "description": "Session identifier"
    },
    "job_id": {
      "type": "string",
      "description": "Job identifier"
    },
    "task_id": {
      "type": ["string", "null"],
      "description": "Task identifier if available"
    },
    "selected_profile": {
      "type": "string",
      "description": "Selected runtime profile",
      "enum": ["fast", "balanced", "hard"]
    },
    "backend": {
      "type": "string",
      "description": "Backend system used",
      "enum": ["ollama", "claude_api"]
    },
    "model": {
      "type": "string",
      "description": "Model identifier"
    },
    "workspace": {
      "type": "object",
      "description": "Workspace state structure"
    },
    "command_results": {
      "type": "array",
      "description": "Results of executed commands",
      "items": {
        "type": "object",
        "properties": {
          "command": {"type": "array", "items": {"type": "string"}},
          "exit_code": {"type": "integer"},
          "stdout": {"type": "string"},
          "stderr": {"type": "string"},
          "duration_seconds": {"type": "number"},
          "timed_out": {"type": "boolean"}
        }
      }
    },
    "final_status": {
      "type": "string",
      "description": "Final execution status",
      "enum": ["success", "failure", "partial"]
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of artifact creation"
    },
    "content_hash": {
      "type": ["string", "null"],
      "description": "SHA256 hash of artifact content"
    },
    "validation_metadata": {
      "type": "object",
      "description": "Validation metadata",
      "properties": {
        "schema_version": {"type": "string"},
        "validated": {"type": "boolean"},
        "validation_timestamp": {"type": "string"}
      }
    },
    "execution_control_ref": {
      "type": ["string", "null"],
      "description": "Optional reference to execution control package"
    }
  },
  "required": ["schema_version", "artifact_kind", "session_id", "job_id", "selected_profile", "backend", "model", "final_status", "created_at"],
  "additionalProperties": false
}
