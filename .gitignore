tmp/

# Normalization guard: local-only archives/checkpoints/backups
.compat-archive/
.compat-usage/
.cutover-checkpoints/
.host-backups/
.maintenance-checkpoints/
.rename-backups/

# Sensitive/local markers
.env.save
.codex
.ssh/

# Historical backup artifacts
*.bak.*
*.bad_codex_*

# Phase migration backups (contain vault snapshots — never commit)
backups/

# Local databases
data/platform_analytics.db

# Phase block backup files (use git history instead)
*.pre-block*

# H1 rollback state — contains deleted credentials, never commit
docs/phase-13/h1-rollback-state/

# Vault tokens and key material (defense in depth; primary location is $HOME)
.vault-token
vault-init-keys.txt
seal-vault-init-keys-MOVE-OFFLINE.txt

# Local databases
data/*.db
data/*.sqlite
data/*.sqlite3

# IDE/OS
.DS_Store
.vscode/
*.swp
*.swo

# Logs
*.log
!docs/**/*.log
docker/structurizr/workspace/workspace.json
docker/structurizr/workspace/.structurizr/
