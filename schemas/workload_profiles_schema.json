{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Workload Profiles Schema",
  "type": "object",
  "required": ["schema_version", "kind", "profiles"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": ["workload_profiles"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "intended_workload_shape",
          "max_retry_count",
          "validation_intensity",
          "orchestration_mode",
          "artifact_expectation_level",
          "preferred_services",
          "escalation_rule"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z_]+$"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "intended_workload_shape": {
            "type": "object",
            "required": ["roadmap_items", "validation_steps", "expected_artifacts", "allowed_files", "forbidden_files"],
            "properties": {
              "roadmap_items": {
                "type": "string"
              },
              "validation_steps": {
                "type": "string"
              },
              "expected_artifacts": {
                "type": "string"
              },
              "allowed_files": {
                "type": "string"
              },
              "forbidden_files": {
                "type": "string"
              }
            }
          },
          "max_retry_count": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "validation_intensity": {
            "type": "string",
            "enum": ["minimal", "moderate", "comprehensive"]
          },
          "orchestration_mode": {
            "type": "string",
            "enum": ["stateless", "stateful", "transactional"]
          },
          "artifact_expectation_level": {
            "type": "string",
            "enum": ["none", "validation_outputs", "planning_and_bundle", "run_result_and_ledger"]
          },
          "preferred_services": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "escalation_rule": {
            "type": "string"
          }
        }
      }
    },
    "risk_tier_classification": {
      "type": "object"
    },
    "profile_selection_hints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
