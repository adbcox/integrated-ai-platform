{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Orchestration Model Schema",
  "type": "object",
  "required": ["schema_version", "kind", "generated_at", "event_types", "job_states", "state_transitions"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "kind": {
      "type": "string",
      "enum": ["orchestration_model"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "event_types": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "payload": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "handler": {
            "type": "string"
          }
        }
      },
      "minItems": 1
    },
    "job_states": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "valid_transitions"],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "valid_transitions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["to", "event"],
              "properties": {
                "to": {
                  "type": "string"
                },
                "event": {
                  "type": "string"
                }
              }
            }
          },
          "final_state": {
            "type": "boolean"
          }
        }
      },
      "minItems": 1
    },
    "state_transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "event"],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "event": {
            "type": "string"
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "effects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "retry_policy": {
      "type": "object",
      "properties": {
        "max_retries": {
          "type": "integer"
        },
        "retry_delay_seconds": {
          "type": "integer"
        },
        "backoff_multiplier": {
          "type": "number"
        },
        "retryable_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "non_retryable_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "failure_policy": {
      "type": "object",
      "properties": {
        "on_validation_failure": {
          "type": "string"
        },
        "on_timeout": {
          "type": "string"
        },
        "on_forbidden_file_modified": {
          "type": "string"
        }
      }
    }
  }
}
