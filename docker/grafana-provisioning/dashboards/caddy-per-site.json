{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "description": "Per-site Caddy access log analysis via Loki",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "single", "sort": "none"}},
      "title": "Request Rate by Host",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
          "expr": "sum by (req_host) (rate({job=\"caddy\"}[5m]))",
          "legendFormat": "{{req_host}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "single", "sort": "none"}},
      "title": "HTTP Error Rate by Host (4xx+5xx)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
          "expr": "sum by (req_host) (rate({job=\"caddy\", resp_status=~\"[45]..\"}[5m]))",
          "legendFormat": "{{req_host}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "single", "sort": "none"}},
      "title": "Top 10 Hosts by Volume (24h)",
      "type": "barchart",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
          "expr": "topk(10, sum by (req_host) (count_over_time({job=\"caddy\"}[24h])))",
          "legendFormat": "{{req_host}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "options": {"dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": false},
      "title": "Log Stream — $host",
      "type": "logs",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
          "expr": "{job=\"caddy\", req_host=\"$host\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["caddy", "loki", "logs"],
