<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.iap.strava-sync</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>/Users/admin/repos/integrated-ai-platform/scripts/sync-strava-to-calendar.py; rc=$?; touch /Users/admin/.platform-logs/strava-sync.heartbeat; exit $rc</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/admin/logs/strava-sync.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/admin/logs/strava-sync.log</string>
</dict>
</plist>
