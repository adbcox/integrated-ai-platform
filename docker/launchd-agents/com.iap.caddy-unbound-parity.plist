<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.iap.caddy-unbound-parity</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>/usr/bin/python3 /Users/admin/repos/integrated-ai-platform/scripts/check-repo-coherence.py caddy-unbound-parity --refresh; rc=$?; touch /Users/admin/.platform-logs/caddy-unbound-parity.heartbeat; exit 0</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>4</integer>
        <key>Minute</key>
        <integer>23</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/Users/admin/.platform-logs/caddy-unbound-parity.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/admin/.platform-logs/caddy-unbound-parity.err</string>
</dict>
</plist>
