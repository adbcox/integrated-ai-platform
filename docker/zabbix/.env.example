# Zabbix 7.4 Environment Configuration - EXAMPLE
# Copy to .env and fill in real values

# PostgreSQL Configuration
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD_HERE
POSTGRES_DB=zabbix

# Zabbix Server Configuration
ZBX_SERVER_NAME=Mac-Mini-AI-Infrastructure
ZBX_DEBUGLEVEL=3
PHP_TZ=America/New_York

# PostgreSQL tuning (Colima VM = 8GB; host has 48GB but Docker VM is capped)
# Conservative settings: ~40 containers already running; leave headroom
# To increase: colima stop && colima start --memory 16 (disrupts all containers)
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_MAINTENANCE_WORK_MEM=128MB
POSTGRES_WORK_MEM=8MB

# Network Configuration
ZBX_SERVER_HOST=192.168.10.145
ZBX_WEB_PORT=10080

# Image Tags
TIMESCALEDB_IMAGE_TAG=latest-pg16
ZABBIX_IMAGE_TAG=alpine-7.4-latest
