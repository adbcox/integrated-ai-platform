{{- /*
  We read `homepage_token` (NOT `api_token`) because that is the
  field plane-sync writes the working V1 token into; `api_token` was
  a dual-field naming holdover that did not validate against Plane
  CE on 2026-05-01. Re-issuing a separate xindex-only token is
  deferred until we have a Plane token-rotation procedure (currently
  manual via the Plane web UI). Read-only consumer per ADR-A-006.
*/ -}}
{{ with secret "secret/data/plane/api" -}}
PLANE_API_TOKEN={{ .Data.data.homepage_token }}
PLANE_URL=http://host.docker.internal:8000
PLANE_WORKSPACE=iap
PLANE_PROJECT_ID=dbcd4476-1e37-4812-a443-0914ec8380fc
{{- end }}
