# Copy to docker/.env and fill in values
# docker/.env is git-ignored — never commit secrets

# ── Host identity ─────────────────────────────────────────────────────────────
DOMAIN=home.local           # base domain for Traefik routing
ACME_EMAIL=you@example.com  # Let's Encrypt notifications
TZ=America/Los_Angeles

PUID=1000
PGID=1000

# ── Mac Mini / Mac Studio split ───────────────────────────────────────────────
# Set EXECUTOR_HOST when the executor runs on Mac Studio instead of locally
EXECUTOR_HOST=mac-studio.local
REMOTE_REPO_ROOT=~/repos/integrated-ai-platform

# Ollama on Mac Studio
OLLAMA_HOST=mac-studio.local:11434

# ── Dashboard ports ───────────────────────────────────────────────────────────
HOMEPAGE_PORT=3000
DASHBOARD_PORT=8080

# Log directory (mapped into dashboard container)
LOG_DIR=/tmp

# Homelab config dir on host
HOMELAB_DIR=/Users/admin/homelab

# ── Service API keys (set after initial service setup) ───────────────────────
HOMEPAGE_VAR_HASS_TOKEN=
HOMEPAGE_VAR_PLEX_TOKEN=
HOMEPAGE_VAR_SONARR_KEY=
HOMEPAGE_VAR_RADARR_KEY=
HOMEPAGE_VAR_PROWLARR_KEY=
HOMEPAGE_VAR_PORTAINER_KEY=
HOMEPAGE_VAR_OWM_KEY=

# *Arr stack (all services on QNAP at 192.168.10.201)
# Find API keys in: Settings → General → Security → API Key
SONARR_URL=http://192.168.10.201:8989
SONARR_API_KEY=

RADARR_URL=http://192.168.10.201:7878
RADARR_API_KEY=

PROWLARR_URL=http://192.168.10.201:9696
PROWLARR_API_KEY=

PLEX_URL=http://192.168.10.201:32400
PLEX_TOKEN=

# ── QNAP NAS ──────────────────────────────────────────────────────────────────
QNAP_URL=http://192.168.10.201
QNAP_USER=admin
QNAP_PASS=

# ── Seedbox ───────────────────────────────────────────────────────────────────
SEEDBOX_HOST=5.nl19.seedit4me
SEEDBOX_USER=seedit4me
SEEDBOX_PASSWORD=
SEEDBOX_PORT=2088

# ── Plane (open-source project management) ───────────────────────────────────
# Start: docker compose -f docker/docker-compose-plane.yml up -d
# Web UI: http://localhost:3001   API: http://localhost:8000
PLANE_URL=http://localhost:8000
PLANE_SECRET_KEY=change-me-run-openssl-rand-hex-32
PLANE_ADMIN_EMAIL=admin@local.dev
PLANE_ADMIN_PASSWORD=admin123
# Fill these after first login:
PLANE_API_TOKEN=              # Profile → API Tokens → create token
PLANE_WORKSPACE=iap           # workspace slug (set during signup)
PLANE_PROJECT_ID=             # project UUID from URL: /iap/projects/{UUID}/issues/

# MinIO (open-source S3 — replaces AWS S3, NO cloud)
# Web console: http://localhost:9001
MINIO_ROOT_USER=plane
MINIO_ROOT_PASSWORD=          # generate: openssl rand -hex 16
